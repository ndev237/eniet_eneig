# ============================================================
# .env.example — Modèle à copier en .env et à remplir
# ============================================================
# En production : ne PAS créer de .env sur le serveur. Définir ces
# variables dans la plateforme d'hébergement (Render, Railway, Heroku,
# panel cPanel, systemd EnvironmentFile, docker-compose env_file, etc.).

# ---- Django core (OBLIGATOIRES en prod) ----
DJANGO_SECRET_KEY=remplace-par-une-cle-aleatoire-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=eniet-eneig.cm,www.eniet-eneig.cm
DJANGO_CSRF_TRUSTED_ORIGINS=https://eniet-eneig.cm,https://www.eniet-eneig.cm

# ---- Base de données PostgreSQL ----
DJANGO_DB_ENGINE=postgres
DJANGO_DB_NAME=eniet_eneig
DJANGO_DB_USER=eniet_eneig
DJANGO_DB_PASSWORD=change-me-strong-password
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432
DJANGO_DB_SSLMODE=require
DJANGO_DB_CONN_MAX_AGE=60

# ---- Sécurité TLS / HTTPS ----
# Si la plateforme termine déjà le TLS et redirige HTTP→HTTPS,
# mettre DJANGO_SECURE_SSL_REDIRECT=False pour éviter double redirection.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

# ---- Email SMTP ----
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.hostinger.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=noreply@eniet-eneig.cm
DJANGO_EMAIL_HOST_PASSWORD=smtp-password
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=noreply@eniet-eneig.cm
DJANGO_CONTACT_EMAIL=contact@eniet-eneig.cm

# ---- Logging ----
DJANGO_LOG_LEVEL=INFO

# ---- Tailwind (généralement pas nécessaire en prod si statiques pré-compilés) ----
# NPM_BIN_PATH=/usr/bin/npm

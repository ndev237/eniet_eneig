#: .\templates\pages\ecole.html:6
msgid ""
"Découvrez l'histoire, la mission et les valeurs de l'ENIET/ENIEG, école "
"normale d'instituteurs de l'excellence professionnelle à Douala."
msgstr ""
"Discover the history, mission and values of ENIET/ENIEG, a teacher training "
"college of professional excellence in Douala."

#: .\templates\pages\ecole.html:31
msgid "Notre"
msgstr "Our"

#: .\templates\pages\ecole.html:32
msgid "établissement"
